{
  "info": {
    "name": "User Notes API - Week 7",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 or 500', function () {",
                  "  pm.expect([201, 500]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{owner_username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('owner_token', jsonData.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{owner_username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Register Non-owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 or 500', function () {",
                  "  pm.expect([201, 500]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{other_username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login Non-owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('other_token', jsonData.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{other_username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "Create Note For Sharing",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('note_id', jsonData.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{owner_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Week 7 Shared Note\",\n  \"content\": \"This note is shared publicly by token.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/notes",
              "host": ["{{base_url}}"],
              "path": ["notes"]
            }
          }
        }
      ]
    },
    {
      "name": "Week 7 Sharing",
      "item": [
        {
          "name": "Create Share (No Expiration)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('share_id', jsonData.id);",
                  "pm.collectionVariables.set('share_token', jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{owner_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{base_url}}/notes/{{note_id}}/share",
              "host": ["{{base_url}}"],
              "path": ["notes", "{{note_id}}", "share"]
            }
          }
        },
        {
          "name": "Create Share (With Expiration)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('expiring_share_id', jsonData.id);",
                  "pm.collectionVariables.set('expiring_share_token', jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{owner_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expires_at\": \"2099-01-01T00:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/notes/{{note_id}}/share",
              "host": ["{{base_url}}"],
              "path": ["notes", "{{note_id}}", "share"]
            }
          }
        },
        {
          "name": "Public Access #1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('access_count_1', jsonData.share.access_count);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/s/{{share_token}}",
              "host": ["{{base_url}}"],
              "path": ["s", "{{share_token}}"]
            }
          }
        },
        {
          "name": "Public Access #2 (Count Increments)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "var prev = Number(pm.collectionVariables.get('access_count_1'));",
                  "pm.test('access_count increments', function () {",
                  "  pm.expect(jsonData.share.access_count).to.be.above(prev);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/s/{{share_token}}",
              "host": ["{{base_url}}"],
              "path": ["s", "{{share_token}}"]
            }
          }
        },
        {
          "name": "Non-owner List Shares",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 403 or 404', function () {",
                  "  pm.expect([403, 404]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{other_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/notes/{{note_id}}/shares",
              "host": ["{{base_url}}"],
              "path": ["notes", "{{note_id}}", "shares"]
            }
          }
        },
        {
          "name": "Revoke Share",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{owner_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_revoked\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/notes/{{note_id}}/shares/{{share_id}}",
              "host": ["{{base_url}}"],
              "path": ["notes", "{{note_id}}", "shares", "{{share_id}}"]
            }
          }
        },
        {
          "name": "Public Access Revoked Link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 410', function () {",
                  "  pm.response.to.have.status(410);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/s/{{share_token}}",
              "host": ["{{base_url}}"],
              "path": ["s", "{{share_token}}"]
            }
          }
        },
        {
          "name": "Public Access Invalid Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/s/invalid-token-week7",
              "host": ["{{base_url}}"],
              "path": ["s", "invalid-token-week7"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "password", "value": "Testpass1" },
    { "key": "owner_username", "value": "week7_owner" },
    { "key": "other_username", "value": "week7_other" },
    { "key": "owner_token", "value": "" },
    { "key": "other_token", "value": "" },
    { "key": "note_id", "value": "" },
    { "key": "share_id", "value": "" },
    { "key": "share_token", "value": "" },
    { "key": "expiring_share_id", "value": "" },
    { "key": "expiring_share_token", "value": "" },
    { "key": "access_count_1", "value": "0" }
  ]
}
