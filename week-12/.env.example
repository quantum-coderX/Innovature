# Database Configuration
DATABASE_URL=postgresql://ecommerce_user:ecommerce_password@localhost:5432/ecommerce_db

# Flask Configuration
APP_ENV=development
FLASK_ENV=development
FLASK_DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000

# JWT
JWT_SECRET_KEY=CHANGE_ME_TO_SOMETHING_RANDOM

# Storage backend: local or s3
STORAGE_BACKEND=local

# Local storage paths
UPLOAD_FOLDER=static/uploads/products
THUMBNAIL_FOLDER=static/uploads/thumbnails

# Upload limits
MAX_IMAGE_SIZE_BYTES=5242880
MAX_IMAGES_PER_PRODUCT=5

# Optional S3 settings (used only when STORAGE_BACKEND=s3)
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=
S3_CUSTOM_DOMAIN=
S3_MEDIA_PREFIX=uploads
