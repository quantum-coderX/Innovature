# Environment Configuration File
# Copy this to .env and fill in ALL required values (no defaults!)

# ==================== Flask Configuration ====================
FLASK_ENV=development
FLASK_APP=main.py
DEBUG=True

# ==================== Database Configuration ====================
# REQUIRED: PostgreSQL connection string
DATABASE_URL=postgresql://auth_user:auth_password@localhost:5432/auth_db

# ==================== JWT Configuration ====================
# REQUIRED: Generate a strong secret key!
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-a-random-32-character-string-in-production

# ==================== Email Configuration (Gmail) ====================
# REQUIRED: Gmail SMTP settings for sending OTP emails
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=

# Note: For Gmail, use an App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
MAIL_DEFAULT_SENDER=

# ==================== OTP Configuration ====================
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# ==================== Account Lockout Configuration ====================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ==================== 2FA Configuration ====================
TWO_FA_REQUIRED=True
ENABLE_EMAIL_OTP=True
ENABLE_TOTP=False

# ==================== Security ====================
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
