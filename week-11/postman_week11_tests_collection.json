{
  "info": {
    "name": "Week 11 - E-commerce Backend Integration Tests",
    "_postman_id": "week11-testing-collection",
    "description": "Integration tests for Week 11 testing assignment. Includes auth, category, product, image, aggregation, and health checks with assertions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000", "type": "string" },
    { "key": "seller_email", "value": "week11_seller@example.com", "type": "string" },
    { "key": "seller_password", "value": "password123", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "category_id", "value": "", "type": "string" },
    { "key": "product_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Register Seller",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 or 400 if already exists', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Week11 Seller\",\n  \"email\": \"{{seller_email}}\",\n  \"password\": \"{{seller_password}}\",\n  \"role\": \"seller\"\n}"
        }
      }
    },
    {
      "name": "2. Login Seller",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Token is returned', function () {",
              "  pm.expect(json.data).to.have.property('access_token');",
              "});",
              "pm.collectionVariables.set('access_token', json.data.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{seller_email}}\",\n  \"password\": \"{{seller_password}}\"\n}"
        }
      }
    },
    {
      "name": "3. Create Category",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 or 400', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 201) {",
              "  var json = pm.response.json();",
              "  pm.collectionVariables.set('category_id', json.data.id);",
              "}",
              "if (!pm.collectionVariables.get('category_id')) {",
              "  pm.sendRequest({",
              "    url: pm.collectionVariables.get('base_url') + '/api/categories',",
              "    method: 'GET'",
              "  }, function (_err, res) {",
              "    if (res && res.code === 200) {",
              "      var body = res.json();",
              "      var found = body.data.find(function (c) { return c.name === 'Week11 Category'; });",
              "      if (found) pm.collectionVariables.set('category_id', found.id);",
              "    }",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": "{{base_url}}/api/categories",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Week11 Category\",\n  \"description\": \"Testing category\"\n}"
        }
      }
    },
    {
      "name": "4. Create Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('product_id', json.data.id);",
              "pm.test('Product id is captured', function () {",
              "  pm.expect(pm.collectionVariables.get('product_id')).to.not.eql('');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": "{{base_url}}/api/products",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Week11 Product\",\n  \"description\": \"Created during integration test\",\n  \"price\": 199.99,\n  \"stock\": 10,\n  \"category_id\": {{category_id}},\n  \"sku\": \"W11-SKU-001\"\n}"
        }
      }
    },
    {
      "name": "5. Get Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Contains expected product name', function () {",
              "  pm.expect(json.data.name).to.eql('Week11 Product');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/products/{{product_id}}"
      }
    },
    {
      "name": "6. Upload Image (requires manual file attach)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 or 400 based on file setup', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": "{{base_url}}/api/products/{{product_id}}/images",
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "images",
              "type": "file",
              "src": []
            }
          ]
        }
      }
    },
    {
      "name": "7. List Product Images",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Images key exists', function () {",
              "  pm.expect(json.data).to.have.property('images');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/products/{{product_id}}/images"
      }
    },
    {
      "name": "8. Aggregation Stats",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Stats payload has total_products', function () {",
              "  pm.expect(json.data).to.have.property('total_products');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/aggregations/stats"
      }
    },
    {
      "name": "9. Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Service status is ok', function () {",
              "  pm.expect(json.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/"
      }
    }
  ]
}
