# Database Configuration
DATABASE_URL=postgresql://ecommerce_user:ecommerce_password@localhost:5432/ecommerce_db

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000

# JWT
JWT_SECRET_KEY=CHANGE_ME_TO_SOMETHING_RANDOM

# ── Week 10: Image Upload Settings ──────────────────────────
UPLOAD_FOLDER=static/uploads/products
THUMBNAIL_FOLDER=static/uploads/thumbnails
MAX_IMAGE_SIZE_BYTES=5242880
MAX_IMAGES_PER_PRODUCT=5
