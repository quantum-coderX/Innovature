{
  "info": {
    "name": "Week 9 - Buyer/Seller E-commerce API",
    "description": "JWT-based buyer/seller ecommerce backend. Follow numbered requests 01-05 first to set up tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:5000" },
    { "key": "token", "value": "" },
    { "key": "product_id", "value": "1" },
    { "key": "cart_id", "value": "1" }
  ],
  "item": [
    {
      "name": "🔧 SETUP: 01 - Health Check",
      "request": { "method": "GET", "url": { "raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": [""] } }
    },
    {
      "name": "👤 SETUP: 02 - Register Seller",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"name\":\"Seller One\",\"email\":\"seller@example.com\",\"password\":\"StrongPass123\",\"role\":1}" },
        "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] }
      }
    },
    {
      "name": "👤 SETUP: 03 - Register Buyer",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"name\":\"Buyer One\",\"email\":\"buyer@example.com\",\"password\":\"StrongPass123\",\"role\":2}" },
        "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] }
      }
    },
    {
      "name": "🔐 SETUP: 04 - Login Seller (COPY TOKEN)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "var token = (jsonData && jsonData.data && jsonData.data.access_token) ? jsonData.data.access_token : (jsonData ? jsonData.access_token : null);",
              "if (token) {",
              "  pm.collectionVariables.set('token', token);",
              "  pm.environment.set('token', token);",
              "}",
              "pm.test('Token exists in response', function () {",
              "  pm.expect(token).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"email\":\"seller@example.com\",\"password\":\"StrongPass123\"}" },
        "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
      }
    },
    {
      "name": "🔐 SETUP: 05 - Login Buyer (COPY TOKEN)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "var token = (jsonData && jsonData.data && jsonData.data.access_token) ? jsonData.data.access_token : (jsonData ? jsonData.access_token : null);",
              "if (token) {",
              "  pm.collectionVariables.set('token', token);",
              "  pm.environment.set('token', token);",
              "}",
              "pm.test('Token exists in response', function () {",
              "  pm.expect(token).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"email\":\"buyer@example.com\",\"password\":\"StrongPass123\"}" },
        "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
      }
    },
    {
      "name": "✅ 06 - Seller: Validate Token",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{base_url}}/api/auth/validate", "host": ["{{base_url}}"], "path": ["api", "auth", "validate"] }
      }
    },
    {
      "name": "✅ 07 - Create Category",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": ["pm.environment.set('category_id', pm.response.json().data.id);"]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\"name\":\"Electronics\",\"description\":\"Devices\"}" },
        "url": { "raw": "{{base_url}}/api/categories", "host": ["{{base_url}}"], "path": ["api", "categories"] }
      }
    },
    {
      "name": "✅ 08 - Seller: Create Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": ["pm.environment.set('product_id', pm.response.json().data.id);"]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\"name\":\"Laptop Pro\",\"price\":999.99,\"stock\":10,\"sku\":\"LAPTOP-001\",\"category_id\":1}" },
        "url": { "raw": "{{base_url}}/api/products", "host": ["{{base_url}}"], "path": ["api", "products"] }
      }
    },
    {
      "name": "📦 09 - Public: List Products",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/api/products?search=laptop&page=1&per_page=10", "host": ["{{base_url}}"], "path": ["api", "products"], "query": [{"key":"search","value":"laptop"}] }
      }
    },
    {
      "name": "📦 09b - Public: Filter by Price Range",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/products?min_price=100&max_price=1500&page=1&per_page=10",
          "host": ["{{base_url}}"],
          "path": ["api", "products"],
          "query": [
            {"key":"min_price","value":"100"},
            {"key":"max_price","value":"1500"},
            {"key":"page","value":"1"},
            {"key":"per_page","value":"10"}
          ]
        }
      }
    },
    {
      "name": "📦 09c - Public: Filter by Category + In Stock + Sort",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/products?category_id=1&in_stock=true&sort_by=price&sort_order=asc&page=1&per_page=10",
          "host": ["{{base_url}}"],
          "path": ["api", "products"],
          "query": [
            {"key":"category_id","value":"1"},
            {"key":"in_stock","value":"true"},
            {"key":"sort_by","value":"price"},
            {"key":"sort_order","value":"asc"},
            {"key":"page","value":"1"},
            {"key":"per_page","value":"10"}
          ]
        }
      }
    },
    {
      "name": "📦 10 - Public: Get Product",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/api/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["api", "products", "{{product_id}}"] }
      }
    },
    {
      "name": "🛒 11 - Buyer: Create Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": ["pm.environment.set('cart_id', pm.response.json().data.id);"]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{base_url}}/api/carts", "host": ["{{base_url}}"], "path": ["api", "carts"] }
      }
    },
    {
      "name": "🛒 12 - Buyer: Add Item to Cart",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\"product_id\":{{product_id}},\"quantity\":2}" },
        "url": { "raw": "{{base_url}}/api/carts/{{cart_id}}/items", "host": ["{{base_url}}"], "path": ["api", "carts", "{{cart_id}}", "items"] }
      }
    },
    {
      "name": "🛒 13 - Buyer: Get Cart",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{base_url}}/api/carts/{{cart_id}}", "host": ["{{base_url}}"], "path": ["api", "carts", "{{cart_id}}"] }
      }
    },
    {
      "name": "💳 14 - Buyer: Complete Checkout",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\"status\":\"completed\"}" },
        "url": { "raw": "{{base_url}}/api/carts/{{cart_id}}/status", "host": ["{{base_url}}"], "path": ["api", "carts", "{{cart_id}}", "status"] }
      }
    },
    {
      "name": "📊 15 - Aggregations: Stats",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/api/aggregations/stats", "host": ["{{base_url}}"], "path": ["api", "aggregations", "stats"] }
      }
    },
    {
      "name": "📊 16 - Aggregations: Category Breakdown",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/api/aggregations/category-breakdown", "host": ["{{base_url}}"], "path": ["api", "aggregations", "category-breakdown"] }
      }
    },
    {
      "name": "📊 17 - Aggregations: Cart Analytics",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/api/aggregations/cart-analytics", "host": ["{{base_url}}"], "path": ["api", "aggregations", "cart-analytics"] }
      }
    }
  ]
}
