    {
      "name": "Notes",
      "item": [
        {
          "name": "Get Notes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notes"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "1",
                  "description": "Filter by category ID",
                  "disabled": true
                },
                {
                  "key": "tag",
                  "value": "1",
                  "description": "Filter by tag ID",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "note",
                  "description": "Search in title or content",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Create Note",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Note created successfully\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('title');",
                  "    pm.expect(jsonData).to.have.property('content');",
                  "    pm.collectionVariables.set('note_id', jsonData.id);",
                  "    console.log('New note added to database - ID:', jsonData.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Note\",\n  \"content\": \"This is my note content.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/notes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notes"
              ]
            }
          }
        },
        {
          "name": "Create Note with Category & Tag",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Note created successfully\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.collectionVariables.set('note_id', jsonData.id);",
                  "    console.log('New note added - ID:', jsonData.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Categorized Note\",\n  \"content\": \"Note with category and tags.\",\n  \"category_id\": 1,\n  \"tag_ids\": [1]\n}"
            },
            "url": {
              "raw": "{{base_url}}/notes",
              "host": ["{{base_url}}"],
              "path": ["notes"]
            }
          }
        },
        {
          "name": "Get Note",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const noteId = pm.collectionVariables.get('note_id');",
                  "if (!noteId) { throw new Error('note_id is not set. Run Create Note first.'); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notes/{{note_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notes",
                "{{note_id}}"
              ]
            }
          }
        },
        {
          "name": "Update Note",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const noteId = pm.collectionVariables.get('note_id');",
                  "if (!noteId) { throw new Error('note_id is not set. Run Create Note first.'); }"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Note\",\n  \"content\": \"Updated content.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/notes/{{note_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notes",
                "{{note_id}}"
              ]
            }
          }
        },
        {
          "name": "Delete Note",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const noteId = pm.collectionVariables.get('note_id');",
                  "if (!noteId) { throw new Error('note_id is not set. Run Create Note first.'); }"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 204\", function () {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "",
                  "if (pm.response.code === 204) {",
                  "    pm.collectionVariables.set('note_id', '');",
                  "    console.log('note_id cleared after delete.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notes/{{note_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notes",
                "{{note_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health & Database",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                ""
              ]
            }
          }
        },
        {
          "name": "Get All Notes (Check DB)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Database contains notes\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('Total notes in database: ' + jsonData.length);",
                  "    if (jsonData.length > 0) {",
                  "        console.log('Sample note:', jsonData[0]);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notes"
              ]
            },
            "description": "Retrieve all notes for the authenticated user to check database content"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "note_id",
      "value": ""
    }
  ]
